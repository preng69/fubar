{
  "name": "@dtf/mock",
  "version": "0.1.0",
  "description": "Browser-friendly DTF protocol codec, client, responder, and mock dataset.",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "vite --host 0.0.0.0",
    "frontend:build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "prepare": "npm run build",
    "server": "npm run build && node server/server.js",
    "download": "npm run build && node server/server.js download",
    "server:smoke": "npm run build && node server/smoke-test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.80.6",
    "@vitejs/plugin-react": "^4.5.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^6.3.5",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
